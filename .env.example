# =================================================================
# automacoes-claude — variáveis globais (multi-plataforma)
# =================================================================

# --- Postgres ---
DATABASE_URL=postgresql://user:pass@localhost:5432/automacoes

# --- LLM ---
LLM_PROVIDER=openai            # openai | anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- WhatsApp (driver pluggable) ---
WHATSAPP_DRIVER=avisaapi       # avisaapi | evolution | zapi
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# --- Email (opcional) ---
EMAIL_PROVIDER=none            # resend | smtp | none
RESEND_API_KEY=
EMAIL_FROM=

# --- Plataformas de pagamento (preencha só as que vai usar) ---
KIWIFY_WEBHOOK_SECRET=
HOTMART_WEBHOOK_SECRET=
SHOPIFY_WEBHOOK_SECRET=
LASTLINK_WEBHOOK_SECRET=
# Adicione novas como: SUA_PLATAFORMA_WEBHOOK_SECRET=...

# --- Identidade do agente comercial ---
AGENT_NAME=Laura
AGENT_OWNER=Matheus
COMPANY_NAME=Sua Empresa

# --- Produtos (até 2 nativos; mais → editar contexts.py) ---
PRODUCT_A_NAME=Produto A
PRODUCT_A_LINK=
PRODUCT_B_NAME=Produto B
PRODUCT_B_LINK=

# --- Suporte ---
SUPPORT_WHATSAPP_URL=
CLUB_URL=

# --- Servidor ---
APP_PORT=8000
APP_ENV=production
LOG_LEVEL=INFO
