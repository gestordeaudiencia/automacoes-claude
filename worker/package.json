{
  "name": "automacoes-claude-worker",
  "version": "0.2.0",
  "description": "Cloudflare Worker que recebe webhooks de plataformas de pagamento, valida assinatura e dispara workflows no GHL.",
  "private": true,
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:webhook": "bash scripts/test-webhook.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.91.0"
  }
}
